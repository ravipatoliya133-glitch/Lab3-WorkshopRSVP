@model IEnumerable<Lab3_WorkshopRSVP.Models.Rsvp>

@{
    ViewData["Title"] = "Registrations";
}

<div class="container mt-4">
    <h1>Registrations</h1>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning">
            No registrations yet.
        </div>
    }
    else
    {
        <table class="table table-bordered table-striped mt-3">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Full Name</th>
                    <th>Workshop</th>
                    <th>Accommodation</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int i = 1;
                }
                @foreach (var r in Model)
                {
                    <tr>
                        <td>@i</td>
                        <td>@r.FullName</td>
                        <td>@r.WorkshopTitle</td>
                        <td>@(r.NeedsAccommodation ? "Yes" : "No")</td>
                    </tr>
                    i++;
                }
            </tbody>
        </table>
    }

    <div class="mt-3">
        <a class="btn btn-primary me-2" asp-controller="Workshops" asp-action="RsvpForm">Add Another RSVP</a>
        <a class="btn btn-outline-secondary" asp-controller="Workshops" asp-action="Index">Back</a>
    </div>
</div>

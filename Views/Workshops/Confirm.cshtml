@model Lab3_WorkshopRSVP.Models.Rsvp

@{
    ViewData["Title"] = "Confirmation";
}

<div class="container mt-4">
    <h1>Confirmation</h1>

    <div class="alert alert-success mt-3">
        @ViewData["Message"]
    </div>

    <h4 class="mt-4">Your Details</h4>

    <ul class="list-group mt-2">
        <li class="list-group-item"><strong>Name:</strong> @Model.FullName</li>
        <li class="list-group-item"><strong>Workshop:</strong> @Model.WorkshopTitle</li>
        <li class="list-group-item">
            <strong>Accommodation:</strong> @(Model.NeedsAccommodation ? "Yes" : "No")
        </li>
    </ul>

    <div class="mt-4">
        <a class="btn btn-primary me-2" asp-controller="Workshops" asp-action="Registrations">View All Registrations</a>
        <a class="btn btn-outline-secondary" asp-controller="Workshops" asp-action="Index">Back to Workshops</a>
    </div>
</div>
